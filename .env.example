# Server-only — base URL for the koreaJobApiV2 REST API.
# For Coolify: use internal Docker network URL (e.g. http://apiv2:8000)
# For local dev: http://localhost:8000
API_BASE_URL=http://apiv2:8000

# Public — absolute site URL used for canonical URLs, sitemap, and OG tags.
# For Coolify: set to the generated *.sslip.io URL after first deploy, mark "Available at build time"
# For local dev: leave blank (defaults to http://localhost:3000)
NEXT_PUBLIC_SITE_URL=

# Optional — bump when you want to revalidate the entire job list cache sooner
# than the default 60s. Units: seconds.
# REVALIDATE_JOBS=60
